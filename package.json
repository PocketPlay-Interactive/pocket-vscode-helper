{
  "name": "pocket-vscode-helper",
  "displayName": "Pocket VS Code Helper",
  "description": "VS Code buttons for moving Omni Reup Video cache/runtime files and running common Git actions.",
  "version": "0.0.1",
  "publisher": "pocket",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:pocketHelper.runOmniWorkflow",
    "onCommand:pocketHelper.moveOmniCache",
    "onCommand:pocketHelper.pullLatest",
    "onCommand:pocketHelper.push",
    "onCommand:pocketHelper.commitAndPull",
    "onCommand:pocketHelper.commitAndPush",
    "onCommand:pocketHelper.toggleOutput"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile",
    "vsix": "vsce package --allow-missing-repository",
    "install:local": "npm run vsix && code --install-extension pocket-vscode-helper-0.0.1.vsix --force"
  },
  "contributes": {
    "commands": [
      {
        "command": "pocketHelper.runOmniWorkflow",
        "title": "Move Cache + Git...",
        "category": "Omni",
        "icon": "$(tools)"
      },
      {
        "command": "pocketHelper.moveOmniCache",
        "title": "Move Cache/Runtime Files",
        "category": "Omni",
        "icon": "$(archive)"
      },
      {
        "command": "pocketHelper.pullLatest",
        "title": "Pull Latest Code",
        "category": "Omni",
        "icon": "$(cloud-download)"
      },
      {
        "command": "pocketHelper.push",
        "title": "Push Current Branch",
        "category": "Omni",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "pocketHelper.commitAndPull",
        "title": "Commit Current Changes and Pull",
        "category": "Omni",
        "icon": "$(repo-pull)"
      },
      {
        "command": "pocketHelper.commitAndPush",
        "title": "Commit Current Changes and Push",
        "category": "Omni",
        "icon": "$(repo-push)"
      },
      {
        "command": "pocketHelper.toggleOutput",
        "title": "Toggle Pocket Helper Output",
        "category": "Omni",
        "icon": "$(output)"
      }
    ],
    "configuration": {
      "title": "Pocket VS Code Helper",
      "properties": {
        "pocketHelper.showStatusBarButtons": {
          "type": "boolean",
          "default": true,
          "description": "Show Omni helper buttons in the VS Code status bar."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "pocketHelper.runOmniWorkflow"
        },
        {
          "command": "pocketHelper.moveOmniCache"
        },
        {
          "command": "pocketHelper.pullLatest"
        },
        {
          "command": "pocketHelper.push"
        },
        {
          "command": "pocketHelper.commitAndPull"
        },
        {
          "command": "pocketHelper.commitAndPush"
        },
        {
          "command": "pocketHelper.toggleOutput"
        }
      ],
      "explorer/title": [
        {
          "command": "pocketHelper.runOmniWorkflow",
          "group": "navigation"
        }
      ],
      "scm/title": [
        {
          "command": "pocketHelper.commitAndPull",
          "group": "navigation"
        },
        {
          "command": "pocketHelper.commitAndPush",
          "group": "navigation"
        },
        {
          "command": "pocketHelper.push",
          "group": "navigation"
        },
        {
          "command": "pocketHelper.pullLatest",
          "group": "navigation"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.4.5"
  }
}
